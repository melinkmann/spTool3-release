<Configuration status="TRACE">
  <Properties>
    <!--    <Property name="logDirectory">${sys:user.dir}/spTool3/logging/</Property>-->
    <Property name="logDirectory">${sys:user.home}/spTool3/logging/</Property>
    <Property name="logFileName">spLog.log</Property>
  </Properties>

  <Appenders>
    <!-- File Appender -->
    <RollingFile name="File"
      fileName="${logDirectory}${logFileName}"
      filePattern="${logDirectory}${logFileName}-%d{yyyy-MM-dd}-%i.log">
      level="TRACE">  <!-- Add this line to explicitly set the level to TRACE -->
      <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-5p %c{1}:%L - %m%n"/>
      <Policies>
        <SizeBasedTriggeringPolicy size="10MB"/>
      </Policies>
      <DefaultRolloverStrategy max="10"/>
    </RollingFile>

    <!-- Console Appender -->
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-5p %c{1}:%L - %m%n"/>
      <!--      <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%t] %-5level: %highlight{%msg}{FATAL=bg_red, ERROR=red, WARN=yellow, INFO=green, DEBUG=blue, TRACE=cyan} %n"/>-->

    </Console>
  </Appenders>

  <Loggers>
    <!-- Root Logger -->
    <Root level="TRACE">
      <AppenderRef ref="File"/>
      <AppenderRef ref="Console"/>
    </Root>
  </Loggers>
</Configuration>